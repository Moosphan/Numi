    "account.balance.adjust.desc": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调整余额会直接更新账户当前余额；已有账单仍保留在明细中。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjusting the balance directly updates the current account balance. Existing records remain in the transactions list."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "調整餘額會直接更新帳戶目前餘額；既有帳單仍保留在明細中。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "残高を調整すると、現在の口座残高が直接更新されます。既存の記録は明細に残ります。"
          }
        }
      }
    },
    "account.info.desc": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅统计已开启\"计入资产\"的账户；隐藏账户不会出现在记账页账户选择器中，历史记录仍保留原账户。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only accounts with 'Include in Assets' enabled are counted. Hidden accounts won't appear in the account selector when recording, but historical records keep their original account."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅統計已開啟「計入資產」的帳戶；隱藏帳戶不會出現在記帳頁帳戶選擇器中，歷史記錄仍保留原帳戶。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「資産に含める」が有効な口座のみ集計します。非表示の口座は記録時の口座選択には表示されませんが、過去の記録には元の口座が保持されます。"
          }
        }
      }
    },
