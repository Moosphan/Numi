    "installment.calc.desc": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每期应付 = 总金额 / 期数 + 手续费。系统会自动生成每期记录。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Payment per period = Total / Periods + Fee. The system automatically generates each period's record."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每期應付 = 總金額 / 期數 + 手續費。系統會自動產生每期記錄。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各回の支払額 = 合計金額 / 回数 + 手数料。各回の記録は自動で生成されます。"
          }
        }
      }
    },
