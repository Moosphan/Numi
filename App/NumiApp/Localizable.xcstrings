    "record.transfer.desc": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "转账只调整账户余额，不计入支出或收入。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Transfers only adjust account balances and are not counted as expenses or income."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "轉帳只調整帳戶餘額，不計入支出或收入。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "振替はアカウント残高を調整するだけで、支出や収入には計上されません。"
          }
        }
      }
    },
