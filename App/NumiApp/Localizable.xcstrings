    "category.hide.desc": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭后，该分类不会出现在新增和编辑账单的分类网格中，历史账单仍会保留原分类。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After hiding, this category won't appear in the category grid when adding or editing records. Historical records will keep their original category."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉後，該分類不會出現在新增和編輯帳單的分類網格中，歷史帳單仍會保留原分類。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "非表示にすると、記録の追加や編集時のカテゴリ一覧には表示されません。過去の記録には元のカテゴリが保持されます。"
          }
        }
      }
    },
