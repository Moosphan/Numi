    "setting.ai.api.key.desc": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "API Key 用于 Siri 语音记账功能，调用 AI 解析账单文本。密钥存储在本地，不会上传到任何服务器。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The API Key is used for Siri voice recording, calling AI to parse billing text. The key is stored locally and never uploaded to any server."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "API Key 用於 Siri 語音記帳功能，呼叫 AI 解析帳單文字。密鑰儲存在本機，不會上傳到任何伺服器。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "API Key は Siri 音声記録機能で、AI に記録テキストを解析させるために使います。キーは端末内に保存され、サーバーにはアップロードされません。"
          }
        }
      }
    },
