    "ledger.delete.msg": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除「%@」将同时删除其关联的 %lld 条交易记录和预算设置，此操作不可撤销。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deleting '%@' will also delete %lld transaction records and budget settings. This cannot be undone."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除「%@」將同時刪除其關聯的 %lld 筆交易記錄和預算設定，此操作無法復原。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」を削除すると、関連する %lld 件の取引記録と予算設定も削除されます。この操作は元に戻せません。"
          }
        }
      }
    },
    "ledger.info": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "账本用于隔离不同场景的账单数据。切换账本后，交易列表、统计和预算都会随之变化。分类和账户在所有账本间共享。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ledgers help separate billing data for different scenarios. Switching ledgers changes the transaction list, statistics, and budgets. Categories and accounts are shared across all ledgers."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "帳本用於隔離不同情境的帳單資料。切換帳本後，交易列表、統計和預算都會隨之變化。分類和帳戶在所有帳本間共享。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "台帳は、シーンごとに記録データを分けるために使います。台帳を切り替えると、取引一覧、統計、予算も切り替わります。カテゴリと口座はすべての台帳で共有されます。"
          }
        }
      }
    },
