{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "intent.record.title": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快速记账"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Record"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "快速記帳"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クイック記録"
          }
        }
      }
    },
    "intent.record.description": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过语音快速记录一笔账单"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quickly record a transaction via voice"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "透過語音快速記錄一筆帳單"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声で取引をすばやく記録"
          }
        }
      }
    },
    "intent.param.content": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "账单内容"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Transaction content"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "帳單內容"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "取引内容"
          }
        }
      }
    },
    "intent.error.no.categories": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先在应用中设置分类"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please set up categories in the app first"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請先在應用中設定分類"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まずアプリでカテゴリを設定してください"
          }
        }
      }
    },
    "intent.error.no.key": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先在设置中配置 AI 服务密钥"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please configure the AI service key in Settings first"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請先在設定中配置 AI 服務密鑰"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まず設定でAIサービスキーを設定してください"
          }
        }
      }
    },
    "intent.success": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已记录 %@ %@%@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recorded %@ %@%@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已記錄 %@ %@%@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ %@%@を記録しました"
          }
        }
      }
    },
    "intent.fail": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记账失败：%@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recording failed: %@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記帳失敗：%@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記録失敗：%@"
          }
        }
      }
    },
    "intent.shortTitle": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快速记账"
          }
        },
        "en": {
          "stringUnit": {
