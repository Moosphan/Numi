      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用 %@ 记一笔 %@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Record %@ with %@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用 %@ 記一筆 %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@で%@を記録"
          }
        }
      }
